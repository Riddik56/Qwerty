OPENROUTER_API_KEY=your_openrouter_key_here

# Email notifications (required on Render for enrollment/contact alerts)
# Yandex example:
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_mail@yandex.ru
SMTP_PASS=your_app_password
SMTP_FROM=Интерактив <your_mail@yandex.ru>
NOTIFY_EMAIL_TO=your_mail@yandex.ru
